{
  "name": "BambuBuddy",
  "version": "1.2.0",
  "slug": "bambuddy",
  "description": "Self-hosted Bambu Lab companion",
  "url": "https://github.com/holter12/bambuddy-ha-addon",

  "startup": "services",
  "boot": "auto",
  "init": false,

  "arch": ["aarch64", "amd64"],

  "ingress": true,
  "ingress_port": 8000,
  "panel_icon": "mdi:printer-3d",

  "host_network": true,

  "ports": {
    "8000/tcp": 8000
  },

  "ports_description": {
    "8000/tcp": "Web Interface"
  },

  "map": [
    "config:rw",
    "ssl"
  ],

  "environment": {
    "TZ": "UTC"
  },

  "options": {
    "port": 8000,
    "log_level": "info"
  },

  "schema": {
    "port": "int(1024,65535)",
    "log_level": "list(trace|debug|info|warning|error|fatal)"
  },

  "homeassistant": "2024.6.0"
}